# agentbox environment - rendered from files/agentbox/agentbox.env.j2 with
# values from vault/secrets.yaml. Mode 0600.
#
# IMPORTANT: ANTHROPIC_API_KEY is deliberately NOT set here. Claude Code must
# authenticate with the Pro/Max subscription; an API key in the environment
# silently overrides that and bills per token. Keep it absent everywhere Claude
# Code runs. opencode uses only the free lanes below (local GPU + Gemini free).

# Free lanes
GOOGLE_GENERATIVE_AI_API_KEY={{ ai_services.google_gemini.api_key | default('') }}
LLAMA_API_KEY={{ ai_services.llamacpp.api_keys.terrac | default('') }}

# GitHub (gh CLI). Empty falls back to interactive `gh auth login` done once on
# the box. A vaulted fine-grained PAT with PR write enables unattended operation.
GH_TOKEN={{ (agentbox | default({})).github_pat | default('') }}

# Google APIs (gcloud / client libs). Service-account JSON is written to this
# path by the playbook when agentbox.gcloud_sa_json is populated in the vault.
GOOGLE_APPLICATION_CREDENTIALS={{ home }}/.config/agentbox/gcloud-sa.json

# Deployable repos the watcher resolves issues for (space-separated, owner/repo
# resolved against bluefishforsale).
AGENTBOX_REPOS="{{ agentbox_repos | join(' ') }}"

# Opt-in auto-merge allowlist (ADR 0001). Default empty: every PR waits for a
# human merge. A repo here auto-merges ONLY diffs with no prod-affecting paths.
AGENTBOX_AUTOMERGE_REPOS="{{ agentbox_automerge_repos | join(' ') }}"

# OpenTelemetry: Claude Code (native) pushes metrics + logs to the local
# collector. opencode picks up the same OTLP endpoint via its otel plugin. The
# scripts set OTEL_RESOURCE_ATTRIBUTES per repo/lane on each invocation.
CLAUDE_CODE_ENABLE_TELEMETRY=1
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
