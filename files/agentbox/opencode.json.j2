{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "local-llama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ocean llama.cpp (local GPU)",
      "options": {
        "baseURL": "http://llama.home/v1",
        "apiKey": "{env:LLAMA_API_KEY}"
      },
      "models": {
        "qwen3-14b": { "name": "Qwen3 14B (local GPU, free)" }
      }
    },
    "google": {
      "options": {
        "apiKey": "{env:GOOGLE_GENERATIVE_AI_API_KEY}"
      },
      "models": {
        "gemini-2.5-flash": { "name": "Gemini 2.5 Flash (AI Studio free)" }
      }
    }
  },
  "model": "local-llama/qwen3-14b",
  "small_model": "local-llama/qwen3-14b",
  "agent": {
    "plan": { "model": "google/gemini-2.5-flash" },
    "build": { "model": "local-llama/qwen3-14b" }
  }
}
