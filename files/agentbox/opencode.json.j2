{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@devtheops/opencode-plugin-otel@{{ opencode_otel_plugin_version }}"],
  "instructions": ["{{ home }}/.config/opencode/AGENTS.md"],
  "mcp": {
{% for s in agentbox_mcp_servers %}
    "{{ s.name }}": {% if s.url is defined %}{ "type": "remote", "url": "{{ s.url }}", "enabled": true }{% else %}{ "type": "stdio", "command": {{ ([s.command] + (s.args | default([]))) | to_json }}, "enabled": true }{% endif %}{{ "," if not loop.last else "" }}
{% endfor %}
  },
  "provider": {
    "local-llama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ocean llama.cpp (local GPU)",
      "options": {
        "baseURL": "http://llama.home/v1",
        "apiKey": "{env:LLAMA_API_KEY}"
      },
      "models": {
        "local": { "name": "ocean local GPU (free)" }
      }
    },
    "google": {
      "options": {
        "apiKey": "{env:GOOGLE_GENERATIVE_AI_API_KEY}"
      },
      "models": {
        "gemini-2.5-flash": { "name": "Gemini 2.5 Flash (AI Studio free)" }
      }
    }
  },
  "model": "google/gemini-2.5-flash",
  "small_model": "local-llama/local",
  "agent": {
    "plan": { "model": "google/gemini-2.5-flash" },
    "build": { "model": "google/gemini-2.5-flash" }
  }
}
