[Unit]
Description=Globalview Stack (TimescaleDB + Redis)
Documentation=https://docs.timescale.com/
After=docker.service zfs-mount.service zfs-import.target network-online.target
Wants=network-online.target
Requires=docker.service zfs-mount.service zfs-import.target
RequiresMountsFor=/data01

[Service]
Type=oneshot
RemainAfterExit=yes
User=root
Group=root
WorkingDirectory={{ home }}

Environment=COMPOSE_PROJECT_NAME={{ service }}
Environment=COMPOSE_HTTP_TIMEOUT=60

ExecStartPre=/usr/bin/docker compose -f {{ home }}/docker-compose.yml down --remove-orphans --timeout 30
ExecStartPre=-/usr/bin/docker compose -f {{ home }}/docker-compose.yml pull --quiet
ExecStart=/usr/bin/docker compose -f {{ home }}/docker-compose.yml up -d
ExecStop=/usr/bin/docker compose -f {{ home }}/docker-compose.yml down

ExecReload=/usr/bin/docker compose -f {{ home }}/docker-compose.yml down
ExecReload=/usr/bin/docker compose -f {{ home }}/docker-compose.yml up -d --force-recreate

Restart=on-failure
RestartSec=30
TimeoutStartSec=180
TimeoutStopSec=60

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths={{ home }}
ReadOnlyPaths=/var/run/docker.sock

StandardOutput=journal
StandardError=journal
SyslogIdentifier={{ service }}

[Install]
WantedBy=multi-user.target
