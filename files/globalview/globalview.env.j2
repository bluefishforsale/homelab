# globalview frontend (React + Cesium SPA) — rendered from
# files/globalview/globalview.env.j2 with values from vault/secrets.yaml.
# Read by the container's docker-entrypoint.sh to template config.js
# served alongside the SPA at /config.js.

# Cesium ion access token (free dev tier).
# Populate vault.globalview.cesium_token to enable terrain/imagery.
CESIUM_TOKEN={{ globalview.cesium_token | default('') }}

# Google Maps API key (street view, place search).
GOOGLE_MAPS_API_KEY={{ globalview.google_maps_token | default('') }}

# Public URL the browser hits for backend HTTP + WebSocket. nginx vhost
# globalview.terrac.com path-routes /api/ to the backend container.
VITE_API_URL=https://globalview.terrac.com/api/v1
