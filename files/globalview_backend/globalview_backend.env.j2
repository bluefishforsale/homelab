# globalview backend (FastAPI + WebSocket) — rendered from
# files/globalview_backend/globalview_backend.env.j2.
# Read by pydantic-settings (env_file = .env in container, but we also
# inject these as compose-level env so values work without an in-container
# .env copy).

# TimescaleDB — globalview_stack playbook deploys the container on the host's
# bridge gateway, with the port reserved in vars/vars_service_ports.yaml.
TIMESCALEDB_URL=postgresql://{{ globalview.postgres_user }}:{{ globalview.postgres_password }}@172.17.0.1:{{ service_ports.globalview_stack.postgres }}/{{ globalview.postgres_db }}

# Redis (same stack)
REDIS_URL=redis://172.17.0.1:{{ service_ports.globalview_stack.redis }}

# CORS — restrict to the public hostname the SPA is served from.
ALLOWED_ORIGINS=https://globalview.terrac.com

API_HOST=0.0.0.0
API_PORT={{ port_int }}

# External feed credentials. Empty values mean the relevant scraper runs in
# anonymous/disabled mode where supported. Populate vault.globalview.* to
# enable rate-limit bumps and gated feeds.
OPENSKY_USERNAME={{ globalview.opensky_username | default('') }}
OPENSKY_PASSWORD={{ globalview.opensky_password | default('') }}
AISSTREAM_API_KEY={{ globalview.aisstream_api_key | default('') }}
ICAO_API_KEY={{ globalview.icao_api_key | default('') }}
XCOM_API_KEY={{ globalview.xcom_api_key | default('') }}
XCOM_API_KEY_SECRET={{ globalview.xcom_api_key_secret | default('') }}
XCOM_BEARER_TOKEN={{ globalview.xcom_bearer_token | default('') }}
