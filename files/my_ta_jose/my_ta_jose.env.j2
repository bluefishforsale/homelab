# my-ta-jose - environment file
# Rendered from files/my_ta_jose/my_ta_jose.env.j2 with values from vault/secrets.yaml
# Vault keys live under the top-level `my_ta_jose:` group when added.

# LLM endpoint (llama.cpp on the same host's bridge gateway)
LLAMACPP_BASE_URL=http://172.17.0.1:{{ service_ports.llamacpp.port }}

# Bind address inside the container
APP_HOST=0.0.0.0
APP_PORT={{ port_int }}

# Shared password gate (spec: "Single shared password"). Populated from the
# vault once a my_ta_jose group is added there; placeholder until then.
APP_SHARED_PASSWORD={{ my_ta_jose.shared_password | default('changeme-phase-2-not-yet-set') }}
