# my-ta-jose - environment file
# Rendered from files/my_ta_jose/my_ta_jose.env.j2 with values from vault/secrets.yaml
# Vault keys live under the top-level `my_ta_jose:` group.

# LLM endpoint (llama.cpp on the same host's bridge gateway)
LLAMACPP_BASE_URL=http://172.17.0.1:{{ service_ports.llamacpp.port }}
LLAMACPP_MODEL={{ my_ta_jose.llamacpp_model | default('qwen3-7b') }}

# Bind address inside the container
APP_HOST=0.0.0.0
APP_PORT={{ port_int }}

# Phase-2A authentication.
#
# Password lives in the SQLite DB (data/my_ta_jose.db, mounted volume) so the
# end user can rotate it via /password. APP_INITIAL_PASSWORD_HASH is used
# ONLY on first boot to seed the row; ignored once the row exists. After
# seeding, the operator can blank this value if they want.
#
# SESSION_SECRET signs the session cookies; rotating it invalidates all
# existing sessions (acceptable for one user).
#
# Defaults are intentional placeholders. Missing SESSION_SECRET makes the
# Settings() validation fail and the container crash-loops — better than
# running with a guessable secret.
APP_INITIAL_PASSWORD_HASH={{ my_ta_jose.initial_password_hash | default('') }}
SESSION_SECRET={{ my_ta_jose.session_secret | default('UNSET') }}
SESSION_MAX_AGE_SECONDS={{ my_ta_jose.session_max_age_seconds | default(86400) }}
COOKIE_SECURE={{ my_ta_jose.cookie_secure | default('true') }}
DATABASE_PATH=/app/data/my_ta_jose.db
