[Unit]
Description=Set NVIDIA GPU Power Limit to {{ gpu_power_limit_watts }}W
After=nvidia-persistenced.service
Before=dcgm-exporter.service nvidia-gpu-exporter.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/nvidia-smi -pl {{ gpu_power_limit_watts }}

[Install]
WantedBy=multi-user.target
