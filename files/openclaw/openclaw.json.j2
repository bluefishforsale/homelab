{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-5-20250929",
        "fallbacks": [
          "anthropic/claude-opus-4-6",
          "google/gemini-3-pro-preview",
          "llamacpp//models/Qwen3-14B-Q4_K_M.gguf"
        ]
      },
      "memorySearch": {
        "enabled": true,
        "provider": "openai"
      }
    },
    "list": [
      {
        "id": "assistant",
        "default": true,
        "name": "Assistant",
        "identity": {
          "name": "Assistant",
          "emoji": "💬"
        },
        "model": {
          "primary": "anthropic/claude-sonnet-4-5-20250929",
          "fallbacks": ["google/gemini-3-pro-preview", "llamacpp//models/Qwen3-14B-Q4_K_M.gguf"]
        },
        "subagents": {
          "allowAgents": ["*"],
          "model": {
            "primary": "llamacpp//models/Qwen3-14B-Q4_K_M.gguf",
            "fallbacks": ["anthropic/claude-sonnet-4-5-20250929"]
          }
        }
      },
      {
        "id": "kube-ops",
        "name": "Kube Ops",
        "identity": {
          "name": "Kube Ops",
          "emoji": "☸️"
        },
        "model": {
          "primary": "google/gemini-3-pro-preview",
          "fallbacks": ["anthropic/claude-sonnet-4-5-20250929", "llamacpp//models/Qwen3-14B-Q4_K_M.gguf"]
        },
        "subagents": {
          "allowAgents": ["*"],
          "model": {
            "primary": "google/gemini-3-pro-preview",
            "fallbacks": ["anthropic/claude-sonnet-4-5-20250929"]
          }
        }
      },
      {
        "id": "homelab-ops",
        "name": "Homelab Ops",
        "identity": {
          "name": "Homelab Ops",
          "emoji": "🔧"
        },
        "model": {
          "primary": "google/gemini-3-pro-preview",
          "fallbacks": ["anthropic/claude-sonnet-4-5-20250929", "llamacpp//models/Qwen3-14B-Q4_K_M.gguf"]
        },
        "subagents": {
          "allowAgents": ["*"],
          "model": {
            "primary": "google/gemini-3-pro-preview",
            "fallbacks": ["anthropic/claude-sonnet-4-5-20250929"]
          }
        }
      }
    ]
  },
  "models": {
    "providers": {
      "llamacpp": {
        "baseUrl": "http://192.168.1.143:8080/v1",
        "apiKey": "{{ ai_services.llamacpp.api_key | default('') }}",
        "api": "openai-completions",
        "models": [
          {
            "id": "/models/Qwen3-14B-Q4_K_M.gguf",
            "name": "Qwen3-14B (llamacpp)",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 40960,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "{{ ai_services.openclaw.gateway_token | default('changeme-generate-a-real-token') }}"
    },
    "controlUi": {
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    },
    "trustedProxies": ["192.168.1.143"]
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true,
    "executablePath": "/usr/bin/chromium"
  },
  "channels": {
    "whatsapp": {
      "dmPolicy": "pairing"
    },
    "telegram": {
      "enabled": true,
      "botToken": "{{ ai_services.openclaw.telegram_bot_token | default('') }}",
      "dmPolicy": "pairing",
      "streamMode": "partial"
    },
    "discord": {
      "enabled": true,
      "token": "{{ ai_services.openclaw.discord_bot_token | default('') }}",
      "dmPolicy": "pairing",
      "groupPolicy": "open"
    },
    "slack": {
      "enabled": true
    },
    "signal": {
      "enabled": false
    }
  }
}
