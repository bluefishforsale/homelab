# paia personal AI assistant - environment file
# Rendered from files/paia/paia.env.j2 with values from vault/secrets.yaml.
# Anthropic keys are purpose-specific under ai_services.anthropic_api_keys.<purpose>;
# paia uses the test_main_paia key. Defaults to empty if missing so the deploy
# doesn't crash — bot runs without Claude features and surfaces the
# missing-key error at first use.

PAIA_ANTHROPIC_API_KEY={{ ai_services.anthropic_api_keys.test_main_paia | default('') }}
PAIA_OPENAI_API_KEY={{ ai_services.openai.api_key | default('') }}
PAIA_TAVILY_API_KEY={{ ai_services.tavily.api_key | default('') }}
PAIA_DISCORD_BOT_TOKEN={{ ai_services.openclaw.discord_bot_token | default('') }}
PAIA_DISCORD_ALLOWED_USER_IDS={{ contacts.terrac.discord | default('') }}
