services:
  photonic_inventory:
    image: {{ image }}:{{ version }}
    container_name: {{ service }}
    hostname: {{ service }}
    restart: unless-stopped

    env_file:
      - {{ home }}/.env

    environment:
      - TZ=America/Los_Angeles

    ports:
      - "0.0.0.0:{{ port_ext }}:{{ port_int }}"

    volumes:
      - {{ home }}/data:/data

    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://127.0.0.1:{{ port_int }}/healthz').read()"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 15s

    logging:
      driver: journald
      options:
        tag: "{{ service }}"
