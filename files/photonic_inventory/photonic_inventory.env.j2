# photonic_inventory - environment file
# Rendered from files/photonic_inventory/photonic_inventory.env.j2 with values
# from vault/secrets.yaml. Vault keys live under the top-level
# `photonic_inventory:` group.

DB_PATH=/data/photonic.db

# Bind inside the container; nginx + cloudflared terminate TLS in front.
BIND_HOST=0.0.0.0
BIND_PORT={{ port_int }}
COOKIE_SECURE={{ photonic_inventory.cookie_secure | default('true') }}

# argon2 hashes and signing secrets can contain `$`, which docker-compose v2
# interpolates in unquoted env_file values. Single-quote so compose passes
# them through literally.
SESSION_SECRET='{{ photonic_inventory.session_secret | default("UNSET") }}'
ARGON2_PEPPER='{{ photonic_inventory.argon2_pepper | default("UNSET") }}'

# Seeded on first boot only, if the admin row does not yet exist.
BOOTSTRAP_ADMIN_EMAIL={{ photonic_inventory.bootstrap_admin_email | default('admin@terrac.com') }}
